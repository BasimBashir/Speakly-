# Default: normalize all text files to LF on commit
* text=auto eol=lf

# Shell scripts and env files must always be LF
*.sh text eol=lf
*.env text eol=lf
*.env.* text eol=lf

# Windows-specific files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files — no line-ending normalization
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.whl binary
*.pyc binary

# Auto-generated OpenAPI client. Always regenerate after merging upstream;
# never hand-resolve conflicts. merge=union avoids spurious conflicts when
# both sides add adjacent type/method entries.
ui/src/client/index.ts merge=union
ui/src/client/sdk.gen.ts merge=union
ui/src/client/types.gen.ts merge=union
ui/src/client/client.gen.ts merge=union
sdk/python/src/dograh_sdk/_generated_models.py merge=union
sdk/typescript/src/_generated_models.ts merge=union
