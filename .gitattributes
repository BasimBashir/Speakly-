# Default: normalize all text files to LF on commit
* text=auto eol=lf

# Shell scripts and env files must always be LF
*.sh text eol=lf
*.env text eol=lf
*.env.* text eol=lf

# Windows-specific files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files — no line-ending normalization
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.whl binary
*.pyc binary
